ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# GCP (deploy/gcp.sh)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1

# AWS (deploy/aws.sh)
# Prerequisites: create ECS cluster, ECR repo, IAM execution role, VPC with subnets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ECS_CLUSTER=agentbreeder               # aws ecs create-cluster --cluster-name agentbreeder
AWS_ECR_REPO=agentbreeder                  # aws ecr create-repository --repository-name agentbreeder
AWS_EXECUTION_ROLE_ARN=                    # arn:aws:iam::<account>:role/ecsTaskExecutionRole
AWS_TASK_ROLE_ARN=                         # optional, for Secrets Manager access
AWS_VPC_SUBNETS=                           # comma-separated: subnet-xxx,subnet-yyy
AWS_SECURITY_GROUPS=                       # comma-separated: sg-xxx

# Azure (deploy/azure.sh)
# Prerequisites: az login, create resource group and Container Apps environment
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=agentbreeder-showcase # az group create --name agentbreeder-showcase --location eastus
AZURE_LOCATION=eastus
AZURE_CONTAINER_APPS_ENV=agentbreeder-env  # az containerapp env create --name agentbreeder-env
AZURE_REGISTRY=agentbreeder               # Azure Container Registry name
